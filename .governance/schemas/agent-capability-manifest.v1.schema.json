{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monsoonfire.com/governance/schemas/agent-capability-manifest.v1.schema.json",
  "title": "Agent Capability Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "version",
    "allowed_tools",
    "max_budgets",
    "scope_boundaries",
    "owner_accountable_party"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 2,
      "maxLength": 140
    },
    "version": {
      "type": "string",
      "minLength": 2,
      "maxLength": 140
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "max_budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "runtime_minutes",
        "retries"
      ],
      "properties": {
        "tokens": {
          "type": "integer",
          "minimum": 1
        },
        "runtime_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scope_boundaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner_accountable_party": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200
    }
  }
}

