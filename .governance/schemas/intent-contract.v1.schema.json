{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monsoonfire.com/governance/schemas/intent-contract.v1.schema.json",
  "title": "Governance Intent Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "version",
    "goal",
    "success_criteria",
    "constraints",
    "budgets",
    "allowed_tools",
    "required_evidence",
    "risk_level",
    "authority_gates",
    "stop_conditions"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "goal": {
      "type": "string",
      "minLength": 10,
      "maxLength": 4000
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "statement",
          "metric",
          "operator",
          "target",
          "measurement_method"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,80}$"
          },
          "statement": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          },
          "metric": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "operator": {
            "type": "string",
            "enum": [
              "eq",
              "neq",
              "gt",
              "gte",
              "lt",
              "lte",
              "contains",
              "not_contains"
            ]
          },
          "target": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean"
            ]
          },
          "measurement_method": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must",
        "must_not"
      ],
      "properties": {
        "must": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "must_not": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_changed_files": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "runtime_minutes",
        "retries"
      ],
      "properties": {
        "tokens": {
          "type": "integer",
          "minimum": 1
        },
        "runtime_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterion_id",
          "minimum_tier",
          "accepted_sources"
        ],
        "properties": {
          "criterion_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,80}$"
          },
          "minimum_tier": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "accepted_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "human",
                "ci",
                "test",
                "tool_output",
                "repo_doc",
                "memory",
                "agent_statement"
              ]
            }
          }
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "authority_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "requires_human_approval",
          "trigger"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "requires_human_approval": {
            "type": "boolean"
          },
          "trigger": {
            "type": "string",
            "minLength": 3
          },
          "approved_roles": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            }
          }
        }
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

