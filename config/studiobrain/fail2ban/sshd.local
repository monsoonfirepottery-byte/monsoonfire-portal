[DEFAULT]
# Keep localhost and the current management laptop off the jail path so a
# reboot plus bad auth attempts cannot strand SSH recovery.
ignoreip = 127.0.0.1/8 ::1 192.168.1.141/32

[sshd]
backend = systemd
journalmatch = _SYSTEMD_UNIT=ssh.service + _COMM=sshd
enabled = true
maxretry = 8
findtime = 15m
bantime = 1h
