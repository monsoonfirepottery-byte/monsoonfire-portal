{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monsoonfire.com/contracts/eval-case.schema.json",
  "title": "Intent Eval Case",
  "type": "object",
  "required": ["id", "title", "type", "weight", "required"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240
    },
    "type": {
      "type": "string",
      "enum": [
        "summary.failed_max",
        "summary.blocked_max",
        "summary.succeeded_min",
        "check.succeeded",
        "task.status"
      ]
    },
    "max": { "type": "number" },
    "min": { "type": "number" },
    "status": { "type": "string" },
    "command": { "type": "string", "minLength": 3, "maxLength": 400 },
    "taskId": { "type": "string", "minLength": 3, "maxLength": 240 },
    "weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "required": { "type": "boolean" }
  }
}
