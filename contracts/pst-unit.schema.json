{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pst-unit.schema.json",
  "title": "PST Normalized Unit",
  "type": "object",
  "required": [
    "unitId",
    "unitType",
    "source",
    "content",
    "clientRequestId",
    "metadata"
  ],
  "properties": {
    "unitId": {
      "type": "string",
      "minLength": 1
    },
    "unitType": {
      "type": "string",
      "enum": ["message", "attachment"]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clientRequestId": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
