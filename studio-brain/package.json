{
  "name": "studio-brain",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "env:validate": "node scripts/validate-env-contract.mjs",
    "test:infra": "npm run build && node --test \"lib/infra/**/*.test.js\"",
    "test:connectors": "npm run build && node lib/connectors/testing/runHarness.js",
    "test": "npm run build && node --test \"lib/**/*.test.js\" && node lib/connectors/testing/runHarness.js",
    "test:ci": "npm run build && node --test \"lib/**/*.test.js\" && node lib/connectors/testing/runHarness.js",
    "start": "node lib/index.js",
    "dev": "npm run build && node lib/index.js",
    "preflight": "node scripts/preflight.mjs",
    "compose:validate": "node scripts/validateCompose.mjs",
    "healthcheck": "npm run build && node lib/cli/healthcheck.js",
    "healthcheck:json": "npm run build && node lib/cli/healthcheck.js --output json",
    "memory:ops:supervise": "npm run build && node lib/cli/memoryOpsSupervisor.js",
    "memory:ops:dry-run": "npm run build && node lib/cli/memoryOpsSupervisor.js --dry-run --json",
    "soak": "node scripts/soak.mjs",
    "infra:deps": "npm run compose:validate && npm run healthcheck",
    "infra:integration": "npm run test:infra",
    "export:audit": "npm run build && node lib/cli/exportAudit.js",
    "lint:policy": "node lib/cli/policyLint.js",
    "rebuild": "npm run build && node lib/cli/rebuild.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.8.0",
    "googleapis": "^169.0.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "minio": "^8.0.7",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "redis": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "fast-xml-parser": "^5.5.6",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6"
  }
}
