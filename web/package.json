{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "perf:chunks": "node ./scripts/check-chunk-budgets.mjs",
    "a11y:smoke": "node ./scripts/a11y-smoke.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "node ./node_modules/vitest/vitest.mjs run --configLoader runner",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --configLoader runner",
    "dev:studiobrain": "node ./scripts/dev.mjs",
    "dev:all": "node ./scripts/dev.mjs",
    "check:messages-playwright": "node ./scripts/check-messages-playwright.mjs",
    "check:reservations-journey-playwright": "node ./scripts/check-reservations-journey-playwright.mjs",
    "test:run": "node ./node_modules/vitest/vitest.mjs run --configLoader runner",
    "test:avatar": "node ./node_modules/vitest/vitest.mjs run src/lib/profileAvatars.test.ts --configLoader runner",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.59.1",
    "terser": "^5.46.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
