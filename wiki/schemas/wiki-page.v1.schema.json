{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-page.v1.schema.json",
  "title": "Studio Brain Wiki Page",
  "type": "object",
  "required": [
    "schema",
    "id",
    "title",
    "kind",
    "status",
    "confidence",
    "owner",
    "source_refs",
    "agent_allowed_use"
  ],
  "properties": {
    "schema": { "const": "wiki-page.v1" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": [
        "operational_truth",
        "concept",
        "workflow",
        "decision",
        "contradiction",
        "context_pack",
        "idle_task",
        "audit",
        "deprecated"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "RAW_CAPTURED",
        "EXTRACTED",
        "SYNTHESIZED",
        "VERIFIED",
        "OPERATIONAL_TRUTH",
        "STALE",
        "DEPRECATED",
        "CONTRADICTORY",
        "NEEDS_HUMAN_REVIEW"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "owner": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "last_verified": { "type": ["string", "null"] },
    "valid_until": { "type": ["string", "null"] },
    "last_changed_by": { "type": "string" },
    "agent_allowed_use": {
      "type": "string",
      "enum": ["do_not_use", "cite_only", "planning_context", "operational_context"]
    },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "array", "items": { "type": "string" } },
    "related_pages": { "type": "array", "items": { "type": "string" } },
    "export_hash": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
